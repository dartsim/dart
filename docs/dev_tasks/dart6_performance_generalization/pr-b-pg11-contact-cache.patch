+//==============================================================================
+bool ContactConstraint::isCachedExactContactConstraintType() const
+{
+  if (mCachedIsExactContactConstraintType < 0) {
+#if defined(__clang__)
+  #pragma clang diagnostic push
+  #pragma clang diagnostic ignored "-Wpotentially-evaluated-expression"
+#endif
+    mCachedIsExactContactConstraintType
+        = (typeid(*this) == typeid(ContactConstraint)) ? 1 : 0;
+#if defined(__clang__)
+  #pragma clang diagnostic pop
+#endif
+  }
+  return mCachedIsExactContactConstraintType != 0;
+}
