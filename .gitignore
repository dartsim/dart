# AI agent project files
#
# Shared workflow files may be added under allowlisted command/skill folders.
# Per-developer runtime caches, package installs, locks, and local settings stay
# ignored.
.opencode/*
!.opencode/command/
!.opencode/command/**/*.md
!.opencode/AGENTS.md

!.codex/
.codex/*
!.codex/skills/
!.codex/skills/**/
!.codex/skills/**/SKILL.md
!.codex/AGENTS.md

.claude/*
!.claude/commands/
!.claude/commands/**/*.md
!.claude/skills/
!.claude/skills/**/
!.claude/skills/**/SKILL.md
!.claude/agents/
!.claude/agents/**/*.md
!.claude/hooks/
!.claude/hooks/**/*
!.claude/settings.json

