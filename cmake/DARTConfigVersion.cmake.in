# This version file is used by find_package(DART ... CONFIG).
#
# DART 7 keeps the DART 6.10+ CMake/source compatibility surface required by
# pinned gz-physics integrations. Keep this narrower than AnyNewerVersion so a
# future DART major does not automatically advertise the same legacy range.

set(PACKAGE_VERSION "@DART_VERSION@")
set(PACKAGE_VERSION_MIN_COMPATIBLE "@DART_CMAKE_MIN_COMPATIBLE_VERSION@")

if("${PACKAGE_VERSION}" MATCHES "^([0-9]+)\\.")
  set(_dart_package_version_major "${CMAKE_MATCH_1}")
  if(NOT _dart_package_version_major VERSION_EQUAL 0)
    string(REGEX REPLACE "^0+" "" _dart_package_version_major "${_dart_package_version_major}")
  endif()
else()
  set(_dart_package_version_major "${PACKAGE_VERSION}")
endif()

function(_dart_is_compatible_version requested_version output_variable)
  set(is_compatible FALSE)

  if(NOT requested_version)
    set(is_compatible TRUE)
  elseif(PACKAGE_VERSION VERSION_LESS requested_version)
    set(is_compatible FALSE)
  else()
    if("${requested_version}" MATCHES "^([0-9]+)\\.")
      set(requested_version_major "${CMAKE_MATCH_1}")
      if(NOT requested_version_major VERSION_EQUAL 0)
        string(REGEX REPLACE "^0+" "" requested_version_major "${requested_version_major}")
      endif()
    else()
      set(requested_version_major "${requested_version}")
    endif()

    if(requested_version_major STREQUAL _dart_package_version_major)
      set(is_compatible TRUE)
    elseif(_dart_package_version_major STREQUAL "7"
        AND requested_version VERSION_GREATER_EQUAL PACKAGE_VERSION_MIN_COMPATIBLE
        AND requested_version VERSION_LESS "7.0.0")
      set(is_compatible TRUE)
    endif()
  endif()

  set("${output_variable}" "${is_compatible}" PARENT_SCOPE)
endfunction()

if(PACKAGE_FIND_VERSION_RANGE)
  set(_dart_version_in_requested_range TRUE)

  if(PACKAGE_VERSION VERSION_LESS PACKAGE_FIND_VERSION_MIN)
    set(_dart_version_in_requested_range FALSE)
  elseif(PACKAGE_FIND_VERSION_RANGE_MAX STREQUAL "INCLUDE"
      AND PACKAGE_VERSION VERSION_GREATER PACKAGE_FIND_VERSION_MAX)
    set(_dart_version_in_requested_range FALSE)
  elseif(PACKAGE_FIND_VERSION_RANGE_MAX STREQUAL "EXCLUDE"
      AND NOT PACKAGE_VERSION VERSION_LESS PACKAGE_FIND_VERSION_MAX)
    set(_dart_version_in_requested_range FALSE)
  endif()

  if(_dart_version_in_requested_range)
    _dart_is_compatible_version("${PACKAGE_FIND_VERSION_MIN}" PACKAGE_VERSION_COMPATIBLE)
  else()
    set(PACKAGE_VERSION_COMPATIBLE FALSE)
  endif()
else()
  _dart_is_compatible_version("${PACKAGE_FIND_VERSION}" PACKAGE_VERSION_COMPATIBLE)

  if(PACKAGE_FIND_VERSION STREQUAL PACKAGE_VERSION)
    set(PACKAGE_VERSION_EXACT TRUE)
  endif()
endif()

if("${CMAKE_SIZEOF_VOID_P}" STREQUAL "" OR "@CMAKE_SIZEOF_VOID_P@" STREQUAL "")
  return()
endif()

if(NOT CMAKE_SIZEOF_VOID_P STREQUAL "@CMAKE_SIZEOF_VOID_P@")
  math(EXPR installed_bits "@CMAKE_SIZEOF_VOID_P@ * 8")
  set(PACKAGE_VERSION "${PACKAGE_VERSION} (${installed_bits}bit)")
  set(PACKAGE_VERSION_UNSUITABLE TRUE)
endif()
