material {
    name : dartDebugColor,
    shadingModel : unlit,
    blending : transparent,
    depthWrite : false,
    depthCulling : false,
    doubleSided : true,
    requires : [
        color
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        material.baseColor = getColor();
    }
}
